fname = input("Enter file name: ")
count = 0
if len(fname) < 1:
    fname = "mbox-short.txt"

fh = open(fname)
for line in fh:
    lne = line.split()
    try:
        if lne[0] == "From":
            print(lne[1])
            count = count + 1
    except:
        continue

print("There were", count, "lines in the file with From as the first word")
