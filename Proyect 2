rooms = [2, 1, 3, 2, 5, 1, 4]

HK1 = 0
HK2 = 0

HK1_rooms = []
HK2_rooms = []

for room in rooms:
    if HK1 <= HK2:
        HK1 += room
        HK1_rooms.append(room)
    else:
        HK2 += room
        HK2_rooms.append(room)

print("Housekeeper A:", HK1_rooms, "→", HK1)
print("Housekeeper B:", HK2_rooms, "→", HK2)
